{
    "Inline Math": {
        "prefix": "m",
        "body": [" $${1}$ ${2}"],
        "description": "Insert math block"
    },
    "Outline Math": {
        "prefix": "M",
        "body": ["$$\n${1}\n$$ ${2}"],
        "description": "Insert math block"
    },

    "inline Math": {
        "prefix": "$",
        "body": [" $${1}$ ${2}"],
        "description": "Insert math block"
    },
    "outline Math": {
        "prefix": "$$",
        "body": ["$$\n${1}\n$$ ${2}"],
        "description": "Insert math block"
    },
    "scr" : {
        "prefix": "scr",
        "body": ["\\mathscr{{1}}$ ${2}"],
        "description": "Insert mathscr"
    },
    "bb" : {
        "prefix": "bb",
        "body": ["\\mathbb{{1}}$ ${2}"],
        "description": "Insert mathbb"
    },
    "sum" : {
        "prefix": "sum",
        "body": ["\\sum\\limits_{{1}}^{${2}}$ ${3}"],
        "description": "Insert sum"
    },
    "int" : {
        "prefix": "int",
        "body": ["\\int\\limits_{{1}}^{${2}}$ ${3}"],
        "description": "Insert int"
    }
}
